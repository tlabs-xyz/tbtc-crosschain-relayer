{
  "name": "tbtc-relayer",
  "version": "1.0.0-pre",
  "description": "Threshold Network tBTC Cross-Chain Relayer",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "postinstall": "yarn run prisma:generate",
    "start": "yarn build && yarn db:migrate && node --env-file .env dist/index.js",
    "start:dev": "yarn build && yarn db:migrate && node dist/index.js",
    "start:docker": "docker-compose up",
    "dev": "tsx watch --trace-warnings index.ts",
    "validate-config": "node dist/scripts/validate-config.js",
    "test": "jest --runInBand",
    "test:unit": "jest --config jest.config.unit.cjs --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:watch": "jest --watchAll",
    "prebuild": "yarn clean:build && yarn run prisma:generate",
    "build": "tsc -p tsconfig.build.json",
    "clean:build": "rimraf ./dist ./generated",
    "clean:all": "rimraf ./dist ./generated ./coverage ./node_modules/@prisma/client ./node_modules/@prisma/client-test",
    "fix": "yarn run lint:fix && yarn run format:fix",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:auditlog": "tsx scripts/migrate-auditlog-to-db.ts",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:status": "npx prisma migrate status",
    "postgres:start": "docker run -d --name tbtc-postgres -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=tbtc_relayer -p 5432:5432 postgres:15-alpine",
    "postgres:stop": "docker stop tbtc-postgres && docker rm tbtc-postgres",
    "postgres:logs": "docker logs tbtc-postgres",
    "db:backup": "pg_dump -h $POSTGRES_HOST -U $POSTGRES_USER -d $POSTGRES_DB -F c -b -v -f backup.dump",
    "db:restore": "pg_restore -h $POSTGRES_HOST -U $POSTGRES_USER -d $POSTGRES_DB -v backup.dump",
    "db:reset": "npx prisma db push --force-reset --accept-data-loss",
    "pretest": "docker-compose -f docker-compose.yml -f docker-compose.ci.yml down -v && docker-compose -f docker-compose.yml -f docker-compose.ci.yml up -d postgres",
    "depcheck": "depcheck --ignores @opentelemetry/sdk-trace-node,pino-opentelemetry-transport,pino-pretty,rimraf,@types/jest,improved-yarn-audit,lefthook",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "keywords": [],
  "author": "T-Labs",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "0.28.0",
    "@ethersproject/experimental": "^5.8.0",
    "@keep-network/tbtc-v2.ts": "^3.0.0",
    "@mysten/sui": "^1.34.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "6.9.0",
    "@sentry/node": "^10.44.0",
    "@solana/web3.js": "^1.98.0",
    "@wormhole-foundation/sdk": "2.2.0",
    "bitcoinjs-lib": "^6.1.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "5.8.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "pino-opentelemetry-transport": "^1.1.0",
    "pino-pretty": "^13.0.0",
    "prisma": "6.9.0",
    "rimraf": "^6.0.1",
    "starknet": "=6.0.0",
    "zod": "^3.25.16"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.2",
    "globals": "^16.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@jest/globals": "^29.7.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "depcheck": "^1.4.7",
    "improved-yarn-audit": "^3.0.3",
    "jest": "^29.7.0",
    "lefthook": "^2.1.4",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "resolutions": {
    "@keep-network/random-beacon": "2.1.0-dev.18",
    "@thesis/solidity-contracts": "https://github.com/thesis/solidity-contracts.git#4985bcfc28e36eed9838993b16710e1b500f9e85",
    "@umpirsky/country-list": "https://github.com/umpirsky/country-list.git#05fda51",
    "bip39": "https://github.com/bitcoinjs/bip39.git#d8ea080a18b40f301d4e2219a2991cd2417e83c2",
    "bls12377js": "https://github.com/celo-org/bls12377js.git#400bcaeec9e7620b040bfad833268f5289699cac",
    "scrypt-shim": "https://github.com/web3-js/scrypt-shim.git#aafdadda13e660e25e1c525d1f5b2443f5eb1ebb",
    "websocket": "https://github.com/web3-js/WebSocket-Node.git#ef5ea2f41daf4a2113b80c9223df884b4d56c400"
  }
}
